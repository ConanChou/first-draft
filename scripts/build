#!/bin/sh
# build — thin wrapper around `pnpm build`
set -e

if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
  echo "Usage: build"
  echo ""
  echo "  Thin wrapper around pnpm build."
  exit 0
fi

cd "$(dirname "$0")/.."

if [ -f .env ]; then
  # shellcheck disable=SC1091
  . ./.env
fi

pnpm build

resolved_cname="$CNAME_DOMAIN"

if [ -z "$resolved_cname" ] && [ -n "$SITE_URL" ]; then
  resolved_cname="${SITE_URL#*://}"
  resolved_cname="${resolved_cname%%/*}"
  resolved_cname="${resolved_cname%%:*}"

  case "$resolved_cname" in
    github.io|*.github.io) resolved_cname="" ;;
  esac
fi

if [ -n "$resolved_cname" ]; then
  printf '%s\n' "$resolved_cname" > dist/CNAME
else
  rm -f dist/CNAME
fi
