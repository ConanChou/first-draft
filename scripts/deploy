#!/bin/sh
# deploy — force-push dist/ to the public static-site repo
set -e

if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
  echo "Usage: deploy"
  echo ""
  echo "  Force-push dist/ to the public static-site repo (PUBLIC_REPO in .env)."
  exit 0
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$SCRIPT_DIR/.."

# Load .env
if [ -f "$ROOT/.env" ]; then
  # shellcheck disable=SC1091
  . "$ROOT/.env"
fi

if [ -z "$PUBLIC_REPO" ]; then
  echo "Error: PUBLIC_REPO not set in .env"
  exit 1
fi

SITE_HOST="${SITE_URL#*://}"
SITE_HOST="${SITE_HOST%%/*}"
if [ -z "$SITE_HOST" ]; then
  SITE_HOST="example.com"
fi

DIST="$ROOT/dist"
if [ ! -d "$DIST" ]; then
  echo "Error: dist/ not found — run build first"
  exit 1
fi

STAMP="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

cd "$DIST"
git init -q
git checkout -q -B main
git config user.email "${DEPLOY_GIT_EMAIL:-deploy@$SITE_HOST}"
git config user.name "${DEPLOY_GIT_NAME:-${SITE_NAME:-site} deploy}"
git add -A

if git diff --cached --quiet; then
  echo "deploy: no changes to commit"
else
  git commit -q -m "deploy $STAMP"
fi

git push --force "$PUBLIC_REPO" main

echo "deployed: $STAMP → $PUBLIC_REPO"
