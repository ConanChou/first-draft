#!/usr/bin/env node
/**
 * draft [--lang <code>] [folder]
 * draft --translate <id> --lang <code> [--folder <path>]
 *
 * Creates a new draft or a translation draft, then opens it in the configured editor.
 *
 * New draft:
 *   - allocates the next numeric ID
 *   - creates NNNN[.lang].md in the content library
 *
 * Translation draft:
 *   - reuses an existing ID
 *   - creates NNNN[.lang].md for the target language
 *
 * --lang             language code (default: en for new drafts; required for translations)
 * --translate <id>   create a translation draft for an existing piece
 * --folder <path>    subdirectory relative to CONTENT_PATH
 * folder             positional alias for --folder in new-draft mode
 */

import { writeFileSync, mkdirSync, existsSync } from "node:fs";
import { join, dirname } from "node:path";
import {
  loadEnv, getContentPath, openInEditor, scanMaxId, findById, buildDraftTemplate,
} from "./_lib.mjs";

if (process.argv.includes("--help") || process.argv.includes("-h")) {
  process.stdout.write(
    "Usage: draft [--lang <code>] [folder]\n" +
    "       draft --translate <id> --lang <code> [--folder <path>]\n\n" +
    "  --lang <code>      language code (default: en for new drafts; required for translations)\n" +
    "  --translate <id>   create a translation draft for an existing piece\n" +
    "  --folder <path>    subdirectory relative to CONTENT_PATH\n" +
    "  folder             positional alias for --folder in new-draft mode\n"
  );
  process.exit(0);
}

const env = loadEnv();
const contentPath = getContentPath(env);
const DEFAULT_LANG = env.DEFAULT_LANG ?? "en";

if (!contentPath) {
  console.error("Error: CONTENT_PATH not set in .env");
  process.exit(1);
}
if (!existsSync(contentPath)) {
  console.error(`Error: CONTENT_PATH not found: ${contentPath}`);
  process.exit(1);
}

const args = process.argv.slice(2);
let lang = null;
let folder = null;
let translateId = null;
const positional = [];
for (let i = 0; i < args.length; i++) {
  if (args[i] === "--lang") {
    if (i + 1 >= args.length) {
      console.error("Error: --lang requires a value");
      process.exit(1);
    }
    lang = args[++i];
  } else if (args[i] === "--folder") {
    if (i + 1 >= args.length) {
      console.error("Error: --folder requires a value");
      process.exit(1);
    }
    folder = args[++i];
  } else if (args[i] === "--translate") {
    if (i + 1 >= args.length) {
      console.error("Error: --translate requires a value");
      process.exit(1);
    }
    translateId = args[++i];
  } else {
    positional.push(args[i]);
  }
}

const positionalFolder = positional[0] ?? "";
let effectiveLang = lang ?? DEFAULT_LANG;
let targetDir = folder ? join(contentPath, folder) : (positionalFolder ? join(contentPath, positionalFolder) : contentPath);
let filename = "";

if (translateId) {
  if (!lang) {
    console.error("Error: --translate requires --lang");
    process.exit(1);
  }

  const existing = findById(contentPath, translateId);
  if (existing.length === 0) {
    console.error(`Error: no file with ID ${translateId} found`);
    process.exit(1);
  }

  const padded = String(parseInt(translateId, 10)).padStart(4, "0");
  const langSuffix = effectiveLang !== DEFAULT_LANG ? `.${effectiveLang}` : "";
  targetDir = folder
    ? join(contentPath, folder)
    : (dirname(existing[0]));
  filename = `${padded}${langSuffix}.md`;
} else {
  mkdirSync(targetDir, { recursive: true });
  const maxId = scanMaxId(contentPath);
  const nextId = String(maxId + 1).padStart(4, "0");
  const langSuffix = effectiveLang !== DEFAULT_LANG ? `.${effectiveLang}` : "";
  filename = `${nextId}${langSuffix}.md`;
}

mkdirSync(targetDir, { recursive: true });
const filePath = join(targetDir, filename);
if (existsSync(filePath)) {
  console.error(`Error: ${filePath} already exists`);
  process.exit(1);
}

writeFileSync(filePath, buildDraftTemplate(effectiveLang));
console.log(filePath);

openInEditor(filePath, env);
