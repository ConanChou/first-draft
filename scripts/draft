#!/usr/bin/env node
/**
 * draft [--lang <code>] [folder]
 *
 * Allocates the next numeric ID, creates NNNN.md in the iA Writer library,
 * and opens it in iA Writer.
 *
 * --lang   language code (default: zh); non-default langs add .lang suffix
 * folder   path relative to IA_WRITER_PATH (default: library root)
 */

import { writeFileSync, mkdirSync, existsSync } from "node:fs";
import { join } from "node:path";
import { execFileSync } from "node:child_process";
import { loadEnv, scanMaxId, buildDraftTemplate } from "./_lib.mjs";

if (process.argv.includes("--help") || process.argv.includes("-h")) {
  process.stdout.write(
    "Usage: draft [--lang <code>] [folder]\n\n" +
    "  --lang <code>  language code (default: zh); non-default langs add .lang suffix\n" +
    "  folder         subdirectory relative to IA_WRITER_PATH\n"
  );
  process.exit(0);
}

const env = loadEnv();
const IA_PATH = "IA_WRITER_PATH" in process.env ? process.env.IA_WRITER_PATH : (env.IA_WRITER_PATH ?? "");
const DEFAULT_LANG = env.DEFAULT_LANG ?? "zh";

if (!IA_PATH) {
  console.error("Error: IA_WRITER_PATH not set in .env");
  process.exit(1);
}
if (!existsSync(IA_PATH)) {
  console.error(`Error: IA_WRITER_PATH not found: ${IA_PATH}`);
  process.exit(1);
}

const args = process.argv.slice(2);
let lang = null;
const rest = [];
for (let i = 0; i < args.length; i++) {
  if (args[i] === "--lang") {
    if (i + 1 >= args.length) {
      console.error("Error: --lang requires a value");
      process.exit(1);
    }
    lang = args[++i];
  } else {
    rest.push(args[i]);
  }
}
const folder = rest[0] ?? "";
const effectiveLang = lang ?? DEFAULT_LANG;
const targetDir = folder ? join(IA_PATH, folder) : IA_PATH;

mkdirSync(targetDir, { recursive: true });

const maxId = scanMaxId(IA_PATH);
const nextId = String(maxId + 1).padStart(4, "0");
const langSuffix = effectiveLang !== DEFAULT_LANG ? `.${effectiveLang}` : "";
const filename = `${nextId}${langSuffix}.md`;
const filePath = join(targetDir, filename);

if (existsSync(filePath)) {
  console.error(`Error: ${filePath} already exists`);
  process.exit(1);
}

writeFileSync(filePath, buildDraftTemplate(effectiveLang));
console.log(filePath);

// Open in iA Writer (macOS only — no-op on other platforms)
try {
  execFileSync("open", ["-a", "iA Writer", filePath], { stdio: "ignore" });
} catch {
  // Not macOS or iA Writer not installed — not fatal
}
