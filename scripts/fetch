#!/usr/bin/env node
/**
 * fetch
 *
 * With symlink-based content, there is nothing to copy.
 * This script just verifies the symlink exists; if not, creates it.
 * Called by `publish` before build as a safety check.
 */

import { lstatSync, readlinkSync } from "node:fs";
import { join } from "node:path";
import { execFileSync } from "node:child_process";
import { ROOT, loadEnv } from "./_lib.mjs";

if (process.argv.includes("--help") || process.argv.includes("-h")) {
  process.stdout.write(
    "Usage: fetch\n\n" +
    "  Verifies or creates the src/content → IA_WRITER_PATH symlink.\n" +
    "  Called automatically by publish.\n"
  );
  process.exit(0);
}

const linkPath = join(ROOT, "src", "content");
const env = loadEnv();
const iaPath = env.IA_WRITER_PATH ?? "";

let stat = null;
try { stat = lstatSync(linkPath); } catch { /* doesn't exist */ }

const linkLooksValid = stat?.isSymbolicLink() && iaPath && readlinkSync(linkPath) === iaPath;

if (linkLooksValid) {
  console.log("fetch: src/content symlink ok");
} else {
  console.log("fetch: symlink missing or stale — running link");
  execFileSync(join(ROOT, "scripts", "link"), [], { stdio: "inherit" });
}
