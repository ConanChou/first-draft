---
import Base from "../../layouts/Base.astro";
import EntryItem from "../../components/EntryItem.astro";
import { getAllTags } from "../../lib/content";
import { getFontProfileForLangs } from "../../lib/font-profile";

export async function getStaticPaths() {
  const tags = getAllTags();
  return [...tags.entries()].map(([tag, entries]) => ({
    params: { tag },
    props: {
      tag,
      entries: entries.sort(
        (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime(),
      ),
    },
  }));
}

const { tag, entries } = Astro.props;
const fontProfile = getFontProfileForLangs(entries.map((entry) => entry.lang));
---

<Base title={`#${tag}`} fontProfile={fontProfile}>
  <h1 class="page-heading">#{tag}</h1>
  <ul class="entry-list">
    {entries.map((entry) => <EntryItem entry={entry} />)}
  </ul>
</Base>
