---
import { getStaticPaths as _getStaticPaths, type RouteEntry, type FolderRouteEntry } from "../lib/routes";
import type { GetStaticPathsResult } from "astro";
import Base from "../layouts/Base.astro";
import type { Entry } from "../lib/content";

export async function getStaticPaths(): Promise<GetStaticPathsResult> {
  return _getStaticPaths();
}

type Props =
  | { kind: "post"; entry: RouteEntry; siteUrl: string }
  | { kind: "folder"; folder: FolderRouteEntry; siteUrl: string };

const props = Astro.props as Props;
const { siteUrl } = props;
const isDev = import.meta.env.DEV;

function fmtDate(iso: string) {
  return iso.slice(0, 10);
}

const isFolder = props.kind === "folder";

// Post-specific values
const entry = isFolder ? null : (props as { kind: "post"; entry: RouteEntry }).entry;
// Folder-specific values
const folder = isFolder ? (props as { kind: "folder"; folder: FolderRouteEntry }).folder : null;
const folderChildren = folder
  ? [...folder.children].sort(
      (a, b) => new Date((b as Entry).date).getTime() - new Date((a as Entry).date).getTime()
    )
  : [];

const canonicalUrl = isFolder
  ? `${siteUrl}/${folder!.slug}/`
  : `${siteUrl}/${entry!.slug}/`;
const pageTitle = isFolder ? folder!.title : entry!.title;
const pageLang = isFolder ? folder!.lang : entry!.lang;
---

<Base title={pageTitle} lang={pageLang} canonicalUrl={canonicalUrl}>
  {isFolder ? (
    <div class="section-page">
      <header class="post-header">
        <h1 class="post-title">{folder!.title}</h1>
      </header>
      {folder!.introHtml && (
        <div class="post-body section-intro" set:html={folder!.introHtml} />
      )}
      <ul class="entry-list">
        {folderChildren.map((child) => {
          const e = child as Entry;
          return (
            <li data-lang={e.lang} class:list={[{ draft: e.fm?.draft }]}>
              <span class="entry-num">{e.id}</span>
              <a href={`/${e.slug}/`} class="entry-title">
                {e.title || `(untitled ${e.id})`}
              </a>
              <span class="entry-dots" aria-hidden="true"></span>
              <span class="entry-date">
                {isDev && e.fm?.draft ? "draft" : !e.fm?.draft ? fmtDate(e.date) : ""}
              </span>
            </li>
          );
        })}
      </ul>
    </div>
  ) : (
    <article class="note" data-id={entry!.id}>
      <header class="post-header">
        <h1 class="post-title">{entry!.title}</h1>
        <p class="post-meta">
          <time datetime={entry!.date}>{fmtDate(entry!.date)}</time>
        </p>
        {entry!.translations.length > 0 && (
          <p class="translation-links">
            {entry!.translations.map((lang) => (
              <span>
                Read in <a href={`/${entry!.id}`}>{lang}</a>
              </span>
            ))}
          </p>
        )}
      </header>
      <div class="post-body" set:html={entry!.renderedHtml} />
      {entry!.tags.length > 0 && (
        <div class="post-tags">
          {entry!.tags.map((tag) => (
            <a href={`/tags/${tag}/`}>#{tag}</a>
          ))}
        </div>
      )}
    </article>
  )}
</Base>
