---
import type { GetStaticPathsResult } from "astro";
import Base from "../layouts/Base.astro";
import EntryItem from "../components/EntryItem.astro";
import PostFootnotes from "../components/PostFootnotes.astro";
import { getStaticPaths as routesGetStaticPaths, type RouteEntry, type FolderRouteEntry } from "../lib/routes";
import { getEntryById } from "../lib/content";
import { getFontProfileForLang, getFontProfileForLangs } from "../lib/font-profile";
import { containsModelViewer } from "../lib/render";
import { fmtDate } from "../lib/utils";

export async function getStaticPaths(): Promise<GetStaticPathsResult> {
  return routesGetStaticPaths();
}

type Props =
  | { kind: "post"; entry: RouteEntry; siteUrl: string }
  | { kind: "folder"; folder: FolderRouteEntry; siteUrl: string };

const props = Astro.props as Props;
const { siteUrl } = props;

const LANG_LABELS: Record<string, string> = { zh: "中文", en: "English" };

const canonicalUrl = props.kind === "folder"
  ? `${siteUrl}/${props.folder.slug}/`
  : `${siteUrl}/${props.entry.slug}/`;
const pageTitle = props.kind === "folder" ? props.folder.title : props.entry.title;
const pageLang = props.kind === "folder" ? props.folder.lang : props.entry.lang;
const pageDesc = props.kind === "folder" ? props.folder.description : props.entry.description;

const folderChildren = props.kind === "folder"
  ? [...props.folder.children].sort(
      (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime(),
    )
  : [];
const fontProfile = props.kind === "folder"
  ? getFontProfileForLangs([props.folder.lang, ...folderChildren.map((child) => child.lang)])
  : getFontProfileForLang(props.entry.lang);
const loadModelViewer = props.kind === "folder"
  ? Boolean(props.folder.introHtml && containsModelViewer(props.folder.introHtml))
  : containsModelViewer(props.entry.bodyHtml);

const siblingEntry = props.kind === "post" && props.entry.translations[0]
  ? getEntryById(props.entry.id, props.entry.translations[0]) ?? null
  : null;
---

<Base
  title={pageTitle}
  lang={pageLang}
  canonicalUrl={canonicalUrl}
  description={pageDesc}
  fontProfile={fontProfile}
  loadModelViewer={loadModelViewer}
>
  {props.kind === "folder" ? (
    <div class="section-page">
      <header class="post-header">
        <h1 class="post-title">{props.folder.title}</h1>
      </header>
      {props.folder.introHtml && (
        <div class="post-body section-intro" set:html={props.folder.introHtml} />
      )}
      <ul class="entry-list">
        {folderChildren.map((child) => <EntryItem entry={child} />)}
      </ul>
    </div>
  ) : (
    <article class="note" data-id={props.entry.id}>
      <header class="post-header">
        <h1 class="post-title">{props.entry.title}</h1>
        <p class="post-meta">
          <time datetime={props.entry.date}>{fmtDate(props.entry.date)}</time>
          {siblingEntry && (
            <a
              href={`/${siblingEntry.slug}/`}
              class="lang-switch"
              data-lang={siblingEntry.lang}
            >{LANG_LABELS[siblingEntry.lang] ?? siblingEntry.lang}</a>
          )}
        </p>
      </header>
      <div class="post-body" set:html={props.entry.bodyHtml} />
      {props.entry.tags.length > 0 && (
        <div class="post-tags">
          {props.entry.tags.map((tag) => (
            <a href={`/tags/${tag}/`}>#{tag}</a>
          ))}
        </div>
      )}
      <PostFootnotes />
    </article>
  )}
</Base>
