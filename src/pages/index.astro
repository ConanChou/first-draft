---
import Base from "../layouts/Base.astro";
import { loadAllEntries } from "../lib/content";

// Load all published entries for the home listing
const entries = loadAllEntries().sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);

// Format date as YYYY-MM-DD
function fmtDate(iso: string) {
  return iso.slice(0, 10);
}
---

<Base title="conan.one">
  <ul class="entry-list">
    {
      entries.map((e) => (
        <li data-lang={e.lang}>
          <span class="entry-num">{e.id}</span>
          <a href={`/${e.slug}/`} class="entry-title">{e.title}</a>
          <span class="entry-date">{fmtDate(e.date)}</span>
        </li>
      ))
    }
  </ul>
</Base>
