---
import Base from "../layouts/Base.astro";
import EntryItem from "../components/EntryItem.astro";
import {
  loadAllEntries,
  loadAllFolders,
  type Entry,
  type FolderEntry,
} from "../lib/content";
import { getFontProfileForLangs } from "../lib/font-profile";
import { getSiteDescription, getSiteName } from "../lib/site-config";
import { fmtDate } from "../lib/utils";

const topEntries = loadAllEntries().filter((e) => e.folder === "");
const folders = loadAllFolders();

const items: (Entry | FolderEntry)[] = [...topEntries, ...folders].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime(),
);
const fontProfile = getFontProfileForLangs(items.map((item) => item.lang));

function isFolder(item: Entry | FolderEntry): item is FolderEntry {
  return "children" in item;
}
const siteName = getSiteName();
---

<Base title={siteName} description={getSiteDescription()} fontProfile={fontProfile}>
  <ul class="entry-list">
    {items.map((item) => isFolder(item) ? (
      <li lang={item.lang}>
        <span class="entry-num">▓▓▓▓</span>
        <a href={`/${item.slug}/`} class="entry-title">{item.title}</a>
        <span class="entry-dots" aria-hidden="true"></span>
        <span class="entry-date">{fmtDate(item.date)}</span>
      </li>
    ) : (
      <EntryItem entry={item} />
    ))}
  </ul>
</Base>
