---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  lang?: string;
  ogImage?: string;
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  lang = "zh",
  ogImage,
} = Astro.props;

const siteTitle = "conan.one";
const fullTitle = title === siteTitle ? siteTitle : `${title} — ${siteTitle}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalUrl} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="conan.one (zh)" href="/feed.zh.xml" />
    <link rel="alternate" type="application/rss+xml" title="conan.one (en)" href="/feed.en.xml" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ClientRouter />
  </head>
  <body>
    <a href="/" class="site-logo">
      <img src="/logo.svg" alt="conan.one" width="40" height="40" />
    </a>

    <div class="site-wrap">
      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <span style="margin-left: auto">© {new Date().getFullYear()} Conan</span>
      </footer>
    </div>

    <script>
      const STORAGE_KEY = "preferred-lang";

      function getPreferredLang(): string {
        return localStorage.getItem(STORAGE_KEY) || navigator.language.split("-")[0] || "zh";
      }

      function deduplicateSiblings() {
        const lang = getPreferredLang();
        const groups = new Map<string, HTMLElement[]>();
        document.querySelectorAll<HTMLElement>("li[data-id][data-lang]").forEach((el) => {
          const id = el.dataset.id!;
          if (!groups.has(id)) groups.set(id, []);
          groups.get(id)!.push(el);
        });
        groups.forEach((els) => {
          if (els.length < 2) return;
          const preferred = els.find((el) => el.dataset.lang === lang);
          if (preferred) {
            els.forEach((el) => { el.style.display = el === preferred ? "" : "none"; });
          }
        });
      }

      // Save lang preference when clicking a lang-switch link
      document.addEventListener("click", (e) => {
        const link = (e.target as Element).closest<HTMLAnchorElement>(".lang-switch");
        if (link?.dataset.lang) localStorage.setItem(STORAGE_KEY, link.dataset.lang);
      });

      document.addEventListener("astro:page-load", deduplicateSiblings);
    </script>
  </body>
</html>
