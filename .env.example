# Required.
# Canonical markdown folder. `link`, `draft`, and `publish` read this.
# Can point to any local folder of markdown files. Example below uses iA Writer's library folder.
CONTENT_PATH="/Users/yourname/Library/Mobile Documents/<iA-Writer-Container>/Documents"

# Required.
# Canonical public site URL. Used for metadata, feed URLs, deploy fallback email host,
# and `dist/CNAME` host when `CNAME_DOMAIN` is unset.
SITE_URL="https://example.com"

# Required for deploy.
# Public output repo that receives force-pushed `dist/`.
PUBLIC_REPO="git@github.com:yourname/your-site-output.git"

# Optional. Default from code: "en".
# Default language has flat routes (`/<slug>/`). Non-default langs use `/<lang>/<slug>/`.
DEFAULT_LANG="en"

# Optional. Default from code: "A calm, text-first publishing system."
# Used for site metadata/description.
SITE_DESCRIPTION="A calm, text-first publishing system."

# Optional. Default from code: hostname derived from `SITE_URL`, else "example.com".
# Used in UI, feeds, markdown output, and deploy git-name fallback.
SITE_NAME="example.com"

# Optional. Default from code: `SITE_NAME`, else "Site Owner".
# Used for owner/copyright label.
SITE_OWNER="Site Owner"

# Optional. Default from code: "America/New_York".
# Used by `publish` when no `--tz` flag given.
HOME_TZ="America/New_York"

# Optional. Default from code: 4567.
# Local Micropub server port.
MICROPUB_PORT="4567"

# Optional for normal site build. Required if you use Micropub publish flow.
# No default. Micropub server exits if this is empty.
MICROPUB_TOKEN=""

# Optional. Default from code: "./scripts".
# Advanced Micropub override. Server shells out to `<SCRIPTS_DIR>/publish`.
# Leave unset unless Micropub server runs outside repo root layout.
SCRIPTS_DIR=""

# Optional. Default from code: system `open` command.
# Command prefix used by `draft` to auto-open created files.
# The file path is appended automatically as the final argument.
# Example: OPEN_EDITOR_COMMAND='open -a "iA Writer"'
OPEN_EDITOR_COMMAND=""

# Optional. Default from code: hostname derived from `SITE_URL`.
# Advanced override for `dist/CNAME`. Leave unset for normal custom-domain setups.
# Auto-skipped when derived host is `github.io` or `*.github.io`.
CNAME_DOMAIN=""

# Optional. Default from code: "<SITE_NAME or site> deploy".
# Commit author name used inside transient `dist/.git` during deploy.
DEPLOY_GIT_NAME="site deploy"

# Optional. Default from code: "deploy@<SITE_URL host>".
# Commit author email used inside transient `dist/.git` during deploy.
DEPLOY_GIT_EMAIL="deploy@example.com"
