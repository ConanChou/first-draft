{
  "name": "conan-one",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "node --test 'scripts/**/*.test.mjs' && node --import tsx/esm --test 'src/lib/**/*.test.ts'",
    "test:scripts": "node --test 'scripts/**/*.test.mjs'",
    "test:scripts:pre-commit": "node --test scripts/_lib.test.mjs scripts/build.test.mjs scripts/deploy.test.mjs scripts/fetch.test.mjs scripts/install-script.test.mjs scripts/link.test.mjs scripts/micropub.test.mjs scripts/publish.test.mjs",
    "test:pre-commit": "pnpm test:scripts:pre-commit && pnpm test:lib",
    "test:lib": "node --import tsx/esm --test 'src/lib/**/*.test.ts'",
    "test:zig": "cd scripts/micropub-server && zig build test --summary all"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.6",
    "marked": "^15.0.12",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
